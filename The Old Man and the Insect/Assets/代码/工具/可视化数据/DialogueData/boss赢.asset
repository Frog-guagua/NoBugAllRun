  m_Script: {fileID: 11500000, guid: 0c83d79d798568942a08f4d3426d13ae, type: 3}
  m_Name: "boss\u8D62"
  m_EditorClassIdentifier: 
  dialogueList:
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 0}
    content: "\u6210\u4E86\uFF01\u6210\u4E86\uFF01\u6211\u5C31\u77E5\u9053\u4F60\u80FD\u8D62\uFF0C\u53EF\u592A\u7ED9\u54B1\u80E1\u540C\u51FA\u6C14\u4E86\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u674E\u56DB\u7237"
    speakerSprite: {fileID: 0}
    content: "\u8FD9\u2026\u2026\u8FD9\u2026\u2026\u8FD9\u4E0D\u53EF\u80FD\uFF01\u4E49\u7236\u4ED6\u8FD9\u866B\u80AF\u5B9A\u6709\u95EE\u9898\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 0}
    content: "\u884C\u4E86\uFF0C\u8F93\u4E86\u5C31\u662F\u8F93\u4E86\uFF0C\u6211\u8BA4\u3002\u662F\u6211\u5C0F\u770B\u4F60\u4E86\uFF0C\u4F60\u7684\u6597\u866B\u6280\u5DE7\uFF0C\u786E\u5B9E\u5728\u6211\u4E4B\u4E0A\u2026\u2026"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 0}
    content: "\u8D70\u5427\uFF0C\u4E3A\u4E86\u7ED9\u8FD9\u4F4D\u5144\u5F1F\u966A\u4E2A\u4E0D\u662F\uFF0C\u4ECA\u513F\u4E2A\u6211\u8BF7\u5BA2\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 0}
    content: "\u54CE\u54DF\uFF0C\u592A\u9633\u6253\u897F\u8FB9\u51FA\u6765\u5566\uFF01\u738B\u8001\u54E5\u5C45\u7136\u80AF\u8BF7\u5BA2\u4E86\uFF1F\u90A3\u54B1\u53EF\u4E0D\u80FD\u5BA2\u6C14\uFF01\u8001\u9A6C\uFF0C\u8D70\uFF0C\u4E00\u5757\u513F\u5403\u70B9\u53BB\uFF0C\u6CBE\u4F60\u7684\u5149\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 0}
    content: "\u8F93\u5C31\u8F93\u4E86\uFF0C\u8BDD\u7B97\u6570\u3002\u4E4B\u524D\u662F\u6211\u5634\u81ED\u3001\u51A4\u6789\u4EBA\uFF0C\u8FD9\u987F\u5C31\u5F53\u7ED9\u4F60\u8D54\u4E0D\u662F\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 0}
    content: "\u522B\u6123\u7740\u4E86\uFF0C\u4E00\u5757\u513F\u627E\u4E2A\u5730\u513F\u5750\u5750\uFF0C\u54B1\u8FB9\u5403\u8FB9\u804A\u517B\u866B\u7684\u95E8\u9053\u3002"
    Shake: 0
    canContinue: 1

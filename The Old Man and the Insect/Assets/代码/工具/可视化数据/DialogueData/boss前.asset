  dialogueList:
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\uFF01\uFF01\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 0}
    content: "\u8001\u9A6C\u554A\uFF0C\u8001\u9A6C\uFF01\u4F60\u53EF\u7B97\u6765\u4E86\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 0}
    content: "\u8001\u5218\uFF0C\u8BDD\u53EF\u4E0D\u80FD\u4E71\u8BB2\u3002\u6211\u7684\u866B\u513F\u4ECE\u6765\u90FD\u53EA\u54AC\u80FD\u6253\u7684\uFF0C\u4F60\u90A3\u86D0\u86D0\uFF0C\u5A18\u4E48\u8D56\u8D56\u3001\u8F6F\u8DB4\u8DB4\u7684\uFF0C\u81EA\u5DF1\u5148\u5413\u6B7B\u4E86\uFF0C\u602A\u5F97\u7740\u8C01\uFF1F"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u4F60\u80E1\u8BF4\uFF01\u6211\u90A3\u90FD\u662F\u4E0A\u597D\u7684\u5B9D\u8D1D\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u674E\u56DB\u7237"
    speakerSprite: {fileID: 0}
    content: "\u5F97\u4E86\u5427\u5218\u5927\u7237\uFF0C\u60A8\u90A3\u86D0\u86D0\u513F\u8FDE\u6211\u7684\u90FD\u6597\u4E0D\u8FC7\uFF0C\u8FD8\u60F3\u7740\u627E\u6211\u4E49\u7236\uFF0C\u4E0A\u8D76\u7740\u9001\u7CAE\u6765\u4E86\u561B\u8FD9\u4E0D\u662F\uFF1F\u54C8\u54C8\u54C8\u54C8\u54C8\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 0}
    content: "\u6211\u8FD9\u866B\u513F\u8D62\u5F97\u90FD\u662F\u4E9B\u786C\u832C\uFF0C\u4EC0\u4E48\u65F6\u5019\u5C51\u4E8E\u6597\u4F60\u8FD9\u79CD\u517B\u5E9F\u4E86\u7684\u4E1C\u897F\uFF1F\u8F93\u4E86\u5C31\u8BA4\uFF0C\u53EF\u522B\u5728\u8FD9\u513F\u4E22\u4EBA\u5566\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u8FD9\u4F4D\u5144\u5F1F\uFF0C\u6211\u8001\u8FDC\u5C31\u77A7\u7740\u60A8\u4E86\uFF0C\u8981\u4E0D\u8981\u6765\u548C\u6211\u8FD9\u866B\u513F\u8FC7\u8FC7\u62DB\uFF1F"
    Shake: 0
    canContinue: 1
  - speakerName: "\u738B\u8001\u6C49"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\uFF1F\u8981\u662F\u8D62\u4E86\uFF0C\u6211\u5C31\u628A\u4ECA\u513F\u60A8\u670B\u53CB\u88AB\u54AC\u6B7B\u7684\u86D0\u86D0\u513F\u90FD\u8D54\u4E86\u3002\u8981\u662F\u8F93\u4E86\uFF0C\u4F60\u7684\u866B\u513F\u4E5F\u5F97\u7559\u4E0B\u5F53\u53E3\u7CAE\uFF0C\u610F\u4E0B\u5982\u4F55\uFF1F"
    Shake: 0
    canContinue: 1

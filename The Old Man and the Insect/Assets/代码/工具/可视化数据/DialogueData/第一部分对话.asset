  m_Script: {fileID: 11500000, guid: 0c83d79d798568942a08f4d3426d13ae, type: 3}
  m_Name: "\u7B2C\u4E00\u90E8\u5206\u5BF9\u8BDD"
  m_EditorClassIdentifier: 
  dialogueList:
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u65E9\u554A\u8001\u9A6C\uFF0C\u5230\u4F60\u8FD9\u513F\u6765\u6E9C\u8FBE\u6E9C\u8FBE\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u9A6C\u8001\u95F2"
    speakerSprite: {fileID: 21300000, guid: 98b7e90339efaa14abbc84aa9cb5fb01, type: 3}
    content: "\u5466\uFF0C\u4EC0\u4E48\u98CE\u628A\u60A8\u7ED9\u5439\u6765\u4E86\uFF1F"
    Shake: 0
    canContinue: 1
  - speakerName: "\u9A6C\u8001\u95F2"
    speakerSprite: {fileID: 21300000, guid: 98b7e90339efaa14abbc84aa9cb5fb01, type: 3}
    content: "\u8FD8\u6363\u9F13\u4F60\u90A3\u86D0\u86D0\u513F\u5462\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u8001\u9A6C\u554A\uFF0C\u6211\u8DDF\u4F60\u8BF4\uFF0C\u4ECA\u513F\u6211\u902E\u5230\u8FD9\u51E0\u53EA\u86D0\u86D0\u662F\u771F\u4E0D\u9519\uFF0C\u65E0\u8BBA\u662F\u5916\u89C2\u8FD8\u662F\u6218\u6597\u529B\u90FD\u662F\u5B9E\u6253\u5B9E\u7684\u7A00\u7F55\u7269\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u9A6C\u8001\u95F2"
    speakerSprite: {fileID: 21300000, guid: 98b7e90339efaa14abbc84aa9cb5fb01, type: 3}
    content: "\u563F\uFF0C\u77A7\u7ED9\u60A8\u4E50\u5F97\uFF0C\u8FD9\u662F\u8D76\u7740\u4E0A\u6211\u8FD9\u513F\u663E\u6446\u6765\u4E86\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u4F60\u53C8\u62FF\u6211\u9017\u4E50\uFF0C\u8001\u674E\u554A\uFF0C\u60F3\u5F53\u5E74\u4F60\u53EF\u662F\u54B1\u4EEC\u90A3\u6761\u80E1\u540C\u91CC\u6597\u86D0\u86D0\u513F\u7684\u5934\u4E00\u4EFD\u513F\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u4E0D\u77E5\u5F53\u4E0D\u5F53\u8BB2\uFF0C\u4F60\u4E0D\u5728\u6C5F\u6E56\u8FD9\u4E24\u5E74\u4E0D\u77E5\u9053\u4ECE\u54EA\u8E66\u51FA\u6765\u4E2A\u738B\u8001\u6C49\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u8FD9\u4E3B\u513F\u53EF\u771F\u662F\u6DF7\u4E0D\u541D\uFF0C\u517B\u7684\u90A3\u7FA4\u86D0\u86D0\u513F\u4E4C\u592E\u4E4C\u592E\u7684\uFF0C\u54AC\u6B7B\u8857\u4E0A\u8001\u5934\u513F\u597D\u591A\u86D0\u86D0\u513F\u4E86\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u5C31\u8FDE\u6211\u7684\u2026\u2026.\u55E8\uFF0C\u752D\u63D0\u4E86\u3002\u603B\u4E4B\u8001\u9A6C\u4F60\u4E00\u5B9A\u8981\u7ED9\u6211\u51FA\u8FD9\u53E3\u6C14\u554A\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u9A6C\u8001\u95F2"
    speakerSprite: {fileID: 21300000, guid: 98b7e90339efaa14abbc84aa9cb5fb01, type: 3}
    content: "\u5509\uFF0C\u6211\u8001\u4E86\uFF0C\u65E9\u5C31\u5FD8\u4E86\u600E\u4E48\u517B\u86D0\u86D0\u513F\u4E86\uFF0C\u8BA9\u4ED6\u4EEC\u5E74\u8F7B\u4EBA\u64BA\u6387\u5427\u2026\u2026"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u5C71\u4E2D\u65E0\u8001\u864E\uFF0C\u7334\u5B50\u90FD\u80FD\u79F0\u9738\u738B\u4E86\uFF0C\u8FD9\u738B\u8001\u6C49\u7B97\u662F\u4E2A\u4EC0\u4E48\u4E1C\u897F\u3002"
    Shake: 0
    canContinue: 1
  - speakerName: "\u5218\u5927\u7237"
    speakerSprite: {fileID: 21300000, guid: adc0853ece6621842bf0509813dce594, type: 3}
    content: "\u8001\u9A6C\u5440\uFF0C\u8FD9\u86D0\u86D0\u513F\u4F60\u5C31\u7559\u7740\u5427\uFF0C\u65E9\u665A\u6211\u5C31\u8BA9\u4ED6\u8F93\u7684\u5FC3\u670D\u53E3\u670D\u7684\uFF01"
    Shake: 0
    canContinue: 1
  - speakerName: "\u9A6C\u8001\u95F2"
    speakerSprite: {fileID: 21300000, guid: 98b7e90339efaa14abbc84aa9cb5fb01, type: 3}
    content: "\u54CE\uFF01\u4F60\u628A\u2026\u2026\uFF01\u8FD9\u5BB6\u4F19\u3002"
    Shake: 0
    canContinue: 1
